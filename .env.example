# ── Instagram app (developers.facebook.com → your app → Instagram → API setup with Instagram login)
# Use the *Instagram app ID/secret* shown under the Instagram product, not the parent Meta app's.
IG_APP_ID=
IG_APP_SECRET=
# Must exactly match a redirect URI registered in Business Login settings.
IG_REDIRECT_URI=https://your-app.vercel.app/api/auth/instagram/callback
# Any random string; must match what you type into the webhook setup form.
IG_VERIFY_TOKEN=

# ── Supabase (project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Settings → JWT Keys → "Legacy JWT secret" (long random string, NOT an sb_secret_... key).
SUPABASE_JWT_SECRET=

# ── App session cookie signing key. Generate: openssl rand -hex 32
SESSION_SECRET=

# ── Web push. Generate both with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ── Protects the cron route. Vercel sends it automatically once set in project env.
CRON_SECRET=
