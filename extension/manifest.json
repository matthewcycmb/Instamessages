{
  "manifest_version": 3,
  "name": "Instamessages: Instagram DMs Only",
  "version": "0.1.4",
  "description": "Blocks Instagram's feed, reels, and profiles in your browser. Your DMs and login still work.",
  "permissions": ["declarativeNetRequest"],
  "host_permissions": ["*://*.instagram.com/*"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "cage",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
